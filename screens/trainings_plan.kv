<TrainingPlanScreen>:
    name: 'trainings_plan'

    MDFloatLayout:
        size_hint: 1, 1

        MDBoxLayout:
            orientation: 'vertical'
            size_hint: 1, 1
            pos_hint: {"x": 0, "top": 1}

            ScrollView:
                bar_width: "4dp"
                
                MDList:
                    id: plan_list
                    padding: ["0dp", "0dp", "0dp", "80dp"]

        MDFloatingActionButton:
            icon: "plus"
            md_bg_color: app.theme_cls.primary_color
            opacity: 0.6
            pos_hint: {"center_x": .85, "center_y": .12}
            on_release: root.show_add_dialog()